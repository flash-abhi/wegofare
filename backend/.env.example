# skyfaretravels - Environment Configuration Template
# Copy this file to .env and fill in your actual values

# ========================================
# Server Configuration
# ========================================
PORT=5001
NODE_ENV=development

# ========================================
# JWT Secret for Authentication
# ========================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ========================================
# External Blog Publishing API Keys
# ========================================
# These API keys enable automated blog publishing to high-authority platforms
# If not configured, the system will provide manual publishing instructions instead

# Medium (DA 95) - https://medium.com/me/settings
# Get your integration token from: Settings > Security & Apps > Integration tokens
MEDIUM_API_KEY=your-medium-api-key-here

# Dev.to (DA 90) - https://dev.to/settings/extensions
# Get your API key from: Settings > Extensions > DEV Community API Keys
DEVTO_API_KEY=your-devto-api-key-here

# Hashnode (DA 88) - https://hashnode.com/settings/developer
# Get your personal access token from: Settings > Developer
HASHNODE_API_KEY=your-hashnode-api-key-here
HASHNODE_PUBLICATION_ID=your-hashnode-publication-id

# WordPress.com (DA 92) - https://developer.wordpress.com/apps/
# 1. Create an app at: https://developer.wordpress.com/apps/new/
# 2. Get your access token after OAuth flow
WORDPRESS_API_KEY=your-wordpress-access-token-here
WORDPRESS_SITE_ID=your-wordpress-site-id-or-domain

# Ghost (DA 85) - https://ghost.org/docs/admin-api/
# 1. Go to your Ghost admin panel > Settings > Integrations
# 2. Create a custom integration
# 3. Copy the Admin API Key and API URL
GHOST_ADMIN_API_KEY=your-ghost-admin-api-key-here
GHOST_API_URL=https://your-ghost-site.com

# ========================================
# Security & CAPTCHA Configuration
# ========================================
# CAPTCHA helps prevent automated attacks and phishing attempts
# Choose one provider: recaptcha, hcaptcha, or turnstile

# Enable/disable CAPTCHA (set to 'false' to disable during development)
CAPTCHA_ENABLED=true

# CAPTCHA Provider Selection (recaptcha, hcaptcha, or turnstile)
CAPTCHA_PROVIDER=hcaptcha

# Google reCAPTCHA v3 - https://www.google.com/recaptcha/admin
RECAPTCHA_SITE_KEY=your-recaptcha-site-key
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key

# hCaptcha - https://dashboard.hcaptcha.com/sites
HCAPTCHA_SITE_KEY=your-hcaptcha-site-key
HCAPTCHA_SECRET_KEY=your-hcaptcha-secret-key

# Cloudflare Turnstile - https://dash.cloudflare.com/?to=/:account/turnstile
TURNSTILE_SITE_KEY=your-turnstile-site-key
TURNSTILE_SECRET_KEY=your-turnstile-secret-key

# ========================================
# Email Notifications Configuration
# ========================================
# Email notifications for security alerts

EMAIL_NOTIFICATIONS_ENABLED=false
EMAIL_FROM=security@skyfaretravels.com
ADMIN_EMAILS=info@skyfaretravels.com,security@skyfaretravels.com

# Email Provider (smtp, sendgrid, or mailgun)
EMAIL_PROVIDER=smtp

# SMTP Configuration (Gmail, Office365, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password

# SendGrid API - https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=your-sendgrid-api-key

# Mailgun SMTP - https://app.mailgun.com/app/sending/domains
MAILGUN_SMTP_HOST=smtp.mailgun.org
MAILGUN_SMTP_USER=postmaster@your-domain.mailgun.org
MAILGUN_SMTP_PASS=your-mailgun-smtp-password

# ========================================
# Google Search Console API Configuration
# ========================================
# Enable live Google Search Console integration
# Setup: https://console.cloud.google.com/apis/credentials

# Your website URL in GSC
GSC_SITE_URL=https://skyfaretravels.com

# OAuth2 Credentials from Google Cloud Console
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create OAuth 2.0 Client ID (Web application)
# 3. Add authorized redirect URI: http://localhost:5001/api/gsc/oauth2callback
# 4. Copy Client ID and Client Secret
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5001/api/gsc/oauth2callback

# For production, update redirect URI to:
# GOOGLE_REDIRECT_URI=https://your-domain.com/api/gsc/oauth2callback

# ========================================
# Image Service API Keys (Optional)
# ========================================
# Unsplash API for high-quality travel images
# Get your API key from: https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=your-unsplash-access-key-here

# ========================================
# Additional Platform API Keys (Future)
# ========================================
# LinkedIn Publishing (DA 98)
# LINKEDIN_ACCESS_TOKEN=your-linkedin-token-here

# Tumblr (DA 99)
# TUMBLR_CONSUMER_KEY=your-tumblr-consumer-key
# TUMBLR_CONSUMER_SECRET=your-tumblr-consumer-secret
# TUMBLR_TOKEN=your-tumblr-token
# TUMBLR_TOKEN_SECRET=your-tumblr-token-secret

# Blogger (DA 94)
# BLOGGER_API_KEY=your-blogger-api-key
# BLOGGER_BLOG_ID=your-blogger-blog-id

# ========================================
# GDS System Configuration (Optional)
# ========================================
# Travelport/Galileo credentials
TRAVELPORT_USERNAME=your-travelport-username
TRAVELPORT_PASSWORD=your-travelport-password
TRAVELPORT_TARGET_BRANCH=your-target-branch

# LLC API credentials
LLC_API_KEY=your-llc-api-key
LLC_API_SECRET=your-llc-api-secret

# ========================================
# Email Service Configuration (Optional)
# ========================================
# For marketing campaigns and notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password

# ========================================
# Analytics & SEO Tools (Optional)
# ========================================
# Google Analytics
GOOGLE_ANALYTICS_ID=UA-XXXXXXXXX-X

# Google Search Console
GOOGLE_SEARCH_CONSOLE_KEY=your-search-console-api-key

# ========================================
# Setup Instructions
# ========================================
# 
# 1. Copy this file:
#    cp .env.example .env
#
# 2. Fill in at minimum:
#    - JWT_SECRET (generate a random string)
#    - At least one blog publishing API key (Medium recommended)
#
# 3. Restart the backend server:
#    npm run dev
#
# 4. Test blog publishing from the admin dashboard
#
# For detailed API key setup instructions, see:
# - Medium: https://medium.com/me/settings (Integration tokens)
# - Dev.to: https://dev.to/settings/extensions (API Keys)
# - Hashnode: https://hashnode.com/settings/developer (Personal Access Token)
# - WordPress: https://developer.wordpress.com/apps/ (Create new app)
# - Ghost: Your Ghost admin panel > Settings > Integrations
#
# ========================================
